{
  "manifest_version": 3,
  "name": "PointAsk – Inline AI Follow-ups",
  "version": "0.1.0",
  "description": "Ask follow-up questions about selected points in ChatGPT responses without disrupting the original conversation.",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    { "resources": ["assets/*"], "matches": ["https://chatgpt.com/*"] }
  ],
  "options_ui": { "page": "settings.html", "open_in_tab": true }
}
